  "info": {
    "title": "Web Access Advisor API",
    "description": "Accessibility recording/replay/analysis API. Realtime updates stream over SSE at GET /api/sessions/{id}/events (ADR 0003).",
    "version": "3.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "StartRecordingDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "browserType": {
            "default": "chromium",
            "type": "string",
            "enum": [
              "chromium",
              "firefox",
              "webkit"
            ]
          },
          "browserName": {
            "type": "string"
          },
          "useProfile": {
            "default": false,
            "type": "boolean"
          },
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "reuseStorageStateFrom": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      },
      "StartAuthSegmentDto": {
        "type": "object",
        "properties": {
          "reason": {
            "default": "user-marked",
            "type": "string",
            "enum": [
              "user-marked",
              "auto-detected"
            ]
          },
          "fromStep": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        }
      },
      "StartAnalysisDto": {
        "type": "object",
        "properties": {
          "staticSectionMode": {
            "default": "separate",
            "type": "string",
            "enum": [
              "include",
              "ignore",
              "separate"
            ]
          },
          "captureScreenshots": {
            "default": true,
            "type": "boolean"
          },
          "llmProvider": {
            "type": "string",
            "enum": [
              "gemini",
              "stub",
              "none"
            ]
          }
        }
      },
      "ProfileProbeDto": {
        "type": "object",
        "properties": {
          "browserType": {
            "type": "string",
            "enum": [
              "chromium",
              "firefox",
              "webkit"
            ]
          },
          "browserName": {
            "type": "string"
          }
        },
        "required": [
          "browserType",
          "browserName"
        ]
      },
      "ValidateStorageStateDto": {
        "type": "object",
        "properties": {
          "probeUrl": {
            "type": "string",
            "format": "uri"
          },
          "successSelector": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "integer",
            "exclusiveMinimum": true,
            "maximum": 120000,
            "minimum": 0
          }
        }
      }
    }
  }
}
