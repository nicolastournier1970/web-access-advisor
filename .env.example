# Web Access Advisor — API configuration.
# Copy to .env; `npm run dev` / `npm run dev:api` load it via node --env-file-if-exists.
# Every variable is optional: blank or missing values fall back to the defaults below
# (see apps/api/src/config/env.ts for the authoritative schema).

# Google Gemini API key. When set, AI analysis uses Gemini; when unset, the
# stub provider is used (axe-only results, no cloud calls).
GEMINI_API_KEY=

# Force the LLM provider: gemini | stub. Default: derived from GEMINI_API_KEY.
#LLM_PROVIDER=stub

# Pin a specific Gemini model id. Default: gemini-flash-latest, a rolling alias
# that always points at the current stable Flash model (so Google retiring a
# pinned version can't silently break AI analysis).
#GEMINI_MODEL=gemini-flash-latest

# Gemini thinking-token budget per request. Default 0 (no thinking): Flash
# models otherwise think dynamically, which measurably slows and inflates every
# call and isn't needed for this extraction-style analysis. Raise (e.g. 1024)
# for deeper semantic hunting at higher cost.
#GEMINI_THINKING_BUDGET=0

# Corporate proxy for outbound Gemini requests (only the LLM client uses it).
#HTTPS_PROXY=http://proxy.example.com:8080

# Port for the NestJS API. The Angular dev server proxies /api here.
#API_PORT=3002

# Where session folders (recording.json, step_* snapshots, manifest.json) live.
# Relative paths resolve from the directory you start the API in (repo root).
#SNAPSHOTS_DIR=./snapshots

# Auth-domain patterns used to classify login navigation; edit the JSON file
# itself to add your identity providers — no code change required.
#AUTH_DOMAINS_CONFIG=./config/auth-domains.json

# Run replay/analysis browsers headless. Default: false (headed) — recording in
# a visible browser is the point, and pause-for-login needs a window to sign in.
#PLAYWRIGHT_HEADLESS=false

# How long a replay waits at a login wall before timing out (milliseconds).
#REPLAY_AUTH_TIMEOUT_MS=600000

# Replay speed — per-action page-load settle ceiling (milliseconds). This is
# the main lever: replay waits for the page to fire 'load' after each
# navigate/click, capped here. Lower (e.g. 1500) for snappy sites; raise for
# heavy single-page apps that keep loading. Default 3000.
#REPLAY_LOAD_WAIT_MS=3000

# Multiplier on the fixed "let the DOM react" pauses between replay actions.
# 1 = default; 0.5 = twice as snappy; 2 = more conservative for animated UIs.
#REPLAY_PAUSE_SCALE=1
